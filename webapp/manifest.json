{
  "_version": "1.81.0",
  "sap.app": {
    "id": "useractivitymonitorapplication",
    "type": "application",
    "i18n": {
      "bundleUrl": "i18n/i18n.properties",
      "supportedLocales": ["", "en"],
      "fallbackLocale": "en"
    },
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:fpm",
      "version": "1.20.2",
      "toolsId": "6cb8b9da-d557-4625-885e-83e572fbcf49"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zapi_user_activity/srvd/sap/zsd_user_activity/0001/",
        "type": "OData",
        "settings": {
          "annotations": ["annotation"],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.core": {},
        "sap.viz": {},
        "sap.fe.macros": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "useractivitymonitorapplication.i18n.i18n",
          "supportedLocales": ["", "en"],
          "fallbackLocale": "en"
        }
      },
      "": {
        "type": "sap.ui.model.odata.v4.ODataModel",
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "synchronizationMode": "None",
          "groupId": "$direct"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "style/main.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "controlAggregation": "pages",
        "controlId": "appContent",
        "async": true
      },
      "routes": [
        {
          "name": "authenticate_dataMain",
          "pattern": ":?query:",
          "target": "authenticate_dataMain"
        },
        {
          "name": "AuthDetail",
          "pattern": "AuthDetail({key}):?query:",
          "target": "AuthDetail"
        },
        {
          "name": "UserDetail",
          "pattern": "UserDetail({username}):?query:",
          "target": "UserDetail"
        }
      ],
      "targets": {
        "authenticate_dataMain": {
          "type": "Component",
          "id": "authenticate_dataMain",
          "name": "sap.fe.core.fpm",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/authenticate_data",
              "viewName": "useractivitymonitorapplication.view.Main"
            }
          }
        },
        "AuthDetail": {
          "type": "Component",
          "id": "AuthDetail",
          "name": "sap.fe.core.fpm",
          "options": {
            "settings": {
              "contextPath": "/authenticate_data",
              "viewName": "useractivitymonitorapplication.view.AuthDetail"
            }
          }
        },
        "UserDetail": {
          "type": "Component",
          "id": "UserDetail",
          "name": "sap.fe.core.fpm",
          "options": {
            "settings": {
              "contextPath": "/user_detail",
              "viewName": "useractivitymonitorapplication.view.UserDetail"
            }
          }
        }
      }
    }
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
