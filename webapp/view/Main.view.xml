<mvc:View xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout" height="100%"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:ui="sap.ui.table" controllerName="useractivitymonitorapplication.controller.Main">
    <f:DynamicPage id="MainDynamicPage">
        <!-- TITLE | SUBTITLE -->
        <f:title>
            <f:DynamicPageTitle id="mainDynamicPageTitleId">
                <f:heading>
                    <Title id="titleId" text="{i18n>title}" />
                </f:heading>

                <f:expandedContent>
                    <Label id="subTitleId" text="{i18n>subTitle}" />
                </f:expandedContent>

                <!-- GLOBAL FILTER -->
                <f:actions>
                    <HBox id="globalFilterBox" alignItems="Center" class="sapUiSmallMarginEnd">
                        <VBox id="globalFilterContainer">
                            <Text id="globalFilterLabel" text="{i18n>globalfilter}" class="globalFilterTitle" />
                            <DateRangeSelection id="globalDateRange" change="onGlobalDateRangeChange" width="280px" displayFormat="yyyy-MM-dd" valueFormat="yyyy-MM-dd" delimiter=" - " dateValue="{globalFilterDate>/fromDate}" secondDateValue="{globalFilterDate>/toDate}" />
                        </VBox>
                    </HBox>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <!-- MAIN CONTENT -->
        <f:content>
            <VBox id="MainContent">
                <Panel id="overviewPanel" headerText="{i18n>overviewDashboard}" expandable="true" expanded="true" class="customOverviewPanel sapUiMediumMarginBottom">
                    <content>
                        <VBox id="kpiContainer" class="sapUiSmallMarginTop sapUiMediumMarginBottom">
                            <!-- TITLE + DESCRIPTION -->
                            <VBox id="kpiHeaderBox" class="sapUiSmallMarginBottom">
                                <Title id="kpiTitle" text="{i18n>kpiTitle}" level="H4" />
                                <Text id="kpiDescription" text="{i18n>kpiDescription}" wrapping="true" />
                            </VBox>

                            <!-- KPI BAR -->
                            <HBox id="kpiHBox" justifyContent="Center" wrap="Wrap" class="sapUiSmallMarginTop">
                                <!-- TOTAL USERS -->
                                <VBox id="kpiTotalUsersBox" class="kpiBox kpiBlue">
                                    <core:Icon id="kpiTotalUsersIcon" src="sap-icon://group" size="1.5rem" />
                                    <Text id="kpiTotalUsersLabel" text="{i18n>kpiTotalUsersLabel}" />
                                    <ObjectNumber id="kpiTotalUsersValue" number="{OverviewData>/totalUsers}" textAlign="Center" class="sapUiSmallMarginTop" />
                                </VBox>

                                <!-- TOTAL LOG -->
                                <VBox id="kpiTotalLogBox" class="kpiBox kpiPurple">
                                    <core:Icon id="kpiTotalLogIcon" src="sap-icon://activity-items" size="1.5rem" />
                                    <Text id="kpiTotalLogLabel" text="{i18n>kpiTotalLogLabel}" />
                                    <ObjectNumber id="kpiTotalLogValue" number="{OverviewData>/totalLogs}" textAlign="Center" class="sapUiSmallMarginTop" />
                                </VBox>

                                <!-- SUCCESS LOGIN -->
                                <VBox id="kpiSuccessBox" class="kpiBox kpiGreen">
                                    <core:Icon id="kpiSuccessIcon" src="sap-icon://accept" size="1.5rem" />
                                    <Text id="kpiSuccessLabel" text="{i18n>kpiSuccessLabel}" />
                                    <ObjectNumber id="kpiSuccessValue" number="{OverviewData>/successLogin}" textAlign="Center" class="sapUiSmallMarginTop" />
                                </VBox>

                                <!-- FAILED LOGIN -->
                                <VBox id="kpiFailedBox" class="kpiBox kpiRed">
                                    <core:Icon id="kpiFailedIcon" src="sap-icon://decline" size="1.5rem" />
                                    <Text id="kpiFailedLabel" text="{i18n>kpiFailedLabel}" />
                                    <ObjectNumber id="kpiFailedValue" number="{OverviewData>/failedLogin}" textAlign="Center" class="sapUiSmallMarginTop" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </content>
                </Panel>

                <!-- FILTER + SEARCH -->
                <Panel id="filterPanel" width="100%" headerText="{i18n>filter}" expandable="true" expanded="true" class="customFilterPanel sapUiSmallMarginBottom">
                    <Toolbar id="filterToolbarMain" design="Transparent">
                        <!-- USER -->
                        <Label id="filterLabelUser" text="{i18n>user}" class="sapUiSmallMarginEnd" />
                        <Input id="userSearchId" width="250px" placeholder="{i18n>searchUser}" showValueHelp="true" liveChange="onSearchUserName" valueHelpRequest="onUserSearchHelp" showClearIcon="true" class="sapUiSmallMarginEnd" />

                        <!-- STATUS -->
                        <Label id="filterLabelStatus" text="{i18n>status}" class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />
                        <Select id="MainDropdown" width="180px" change="onFilterStatus" class="sapUiSmallMarginEnd">
                            <core:Item id="filterStatusItemAll" key="" text="{i18n>all}" />
                            <core:Item id="filterStatusItemSuccess" key="SUCCESS" text="{i18n>success}" />
                            <core:Item id="filterStatusItemFail" key="FAIL" text="{i18n>failed}" />
                        </Select>

                        <!-- DATE -->
                        <Label id="filterLabelDate" text="{i18n>filterDate}" class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />
                        <DatePicker id="mainDatePickerId" width="180px" placeholder="{i18n>selectDate}" change="onFilterLoginDate" />
                    </Toolbar>
                </Panel>

                <!-- TABLE -->
                <ui:Table id="MaiTableId" selectionMode="Single" class="sapUiLargeMarginBottom" visibleRowCount="10">
                    <!-- BUTTON -->
                    <ui:extension>
                        <OverflowToolbar id="mainToolbarId">
                            <Title id="mainTitleTableId" text="{= ${i18n>headerTitleTable} + ' (' + ${OverviewData>/totalLogs} + ')' }" level="H2" />

                            <ToolbarSpacer id="mainToolSpace" />

                            <!-- EXPORT BTN -->
                            <Button id="btnExportExcel" icon="sap-icon://excel-attachment" tooltip="{i18n>exportExcel}" press="onExportExcel" />

                            <!-- VIEW SETTINGS BTN -->
                            <Button id="btnViewSettings" icon="sap-icon://action-settings" tooltip="{i18n>viewSettings}" press="onOpenViewSettings" />
                        </OverflowToolbar>
                    </ui:extension>

                    <ui:columns>
                        <!-- SESSION ID COLUMN -->
                        <ui:Column id="columnSession" width="12rem" sortProperty="SessionId" tooltip="{i18n>introSort}">
                            <Label id="labelSession" text="{i18n>sessionId}" />

                            <ui:template>
                                <Text id="textSession" text="{SessionId}" wrapping="false" />
                            </ui:template>
                        </ui:Column>

                        <!-- USERNAME COLUMN -->
                        <ui:Column id="columnName" width="7rem" sortProperty="Username" tooltip="{i18n>introSort}">
                            <Label id="labelName" text="{i18n>username}" />

                            <ui:template>
                                <HBox id="hBoxUser" alignItems="Center" renderType="Bare" class="sapUiTinyMarginBeginEnd">
                                    <core:Icon id="userIcon" src="sap-icon://employee" size="0.9rem" class="sapUiTinyMarginEnd" />
                                    <Link id="textName" tooltip="{i18n>userInfoDetail}" text="{Username}" wrapping="false" press="onNavigateUserDetail" />
                                </HBox>
                            </ui:template>
                        </ui:Column>

                        <!-- LOGIN RESULT COLUMN -->
                        <ui:Column id="columnLoginResult" width="7rem" sortProperty="LoginResult" filterProperty="LoginResult" tooltip="{i18n>introSort}">
                            <Label id="labelLoginResult" text="{i18n>loginResult}" />

                            <ui:template>
                                <ObjectStatus id="textLoginResult" text="{LoginResult}" icon="{path: 'LoginResult', formatter: '.formatter.formatLoginResultIcon'}" state="{path: 'LoginResult', formatter: '.formatter.formatLoginResultState'}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGIN DATE COLUMN -->
                        <ui:Column id="columnLoginDate" width="7rem" sortProperty="LoginDate" tooltip="{i18n>introSort}">
                            <Label id="labelLoginDate" text="{i18n>loginDate}" />

                            <ui:template>
                                <Text id="textLoginDate" text="{path:'LoginDate', formatter: '.formatter.formatISODate'}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGIN TIME COLUMN -->
                        <ui:Column id="columnLoginTime" width="7rem" sortProperty="LoginTime" tooltip="{i18n>introSort}">
                            <Label id="labelLoginTime" text="{i18n>loginTime}" />

                            <ui:template>
                                <Text id="textLoginTime" text="{LoginTime}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGIN MESSAGE COLUMN -->
                        <ui:Column id="columnLoginMessage" width="16rem">
                            <Label id="labelLoginMessage" text="{i18n>loginMessage}" />

                            <ui:template>
                                <ObjectStatus id="textLoginMessage" text="{LoginMessage}" icon="{path: 'EventId', formatter: '.formatter.formatLoginMessageIcon'}" state="{path: 'EventId', formatter: '.formatter.formatLoginMessageState'}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGOUT DATE COLUMN -->
                        <ui:Column id="columnLogoutDate" width="7rem" sortProperty="LogoutDate" tooltip="{i18n>introSort}">
                            <Label id="labelLogoutDate" text="{i18n>logoutDate}" />

                            <ui:template>
                                <Text id="textLogoutDate" text="{path:'LogoutDate', formatter: '.formatter.formatISODate'}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGOUT TIME COLUMN -->
                        <ui:Column id="columnLogoutTime" width="7rem" sortProperty="LogoutTime" tooltip="{i18n>introSort}">
                            <Label id="labelLogoutTime" text="{i18n>logoutTime}" />

                            <ui:template>
                                <Text id="textLogoutTime" text="{path:'LogoutTime', formatter: '.formatter.formatLogoutTime'}" />
                            </ui:template>
                        </ui:Column>

                        <!-- SYSTEM COLUMN -->
                        <ui:Column id="columnSystem" width="4rem" sortProperty="SystemId" tooltip="{i18n>introSort}">
                            <Label id="labelSystem" text="{i18n>systemId}" />

                            <ui:template>
                                <Text id="textSystem" text="{SystemId}" />
                            </ui:template>
                        </ui:Column>

                        <!-- TERMINAL COLUMN -->
                        <ui:Column id="columnTerminal" width="7rem" sortProperty="TerminalId" tooltip="{i18n>introSort}">
                            <Label id="labelTerminal" text="{i18n>terminalId}" />

                            <ui:template>
                                <Text id="textTerminal" text="{TerminalId}" />
                            </ui:template>
                        </ui:Column>

                        <!-- NAVIGATOR COLUMN -->
                        <ui:Column id="columnNavigator" width="4rem" hAlign="Center">
                            <ui:template>
                                <Button id="btnNavigator" tooltip="{i18n>navigateAuth}" icon="sap-icon://navigation-right-arrow" type="Transparent" press="onPressNavigate" />
                            </ui:template>
                        </ui:Column>
                    </ui:columns>
                </ui:Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>