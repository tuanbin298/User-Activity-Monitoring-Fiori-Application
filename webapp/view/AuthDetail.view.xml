<mvc:View xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m" controllerName="useractivitymonitorapplication.controller.AuthDetail"
    xmlns:f="sap.uxap"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:ui="sap.ui.table" height="100%">
    <f:ObjectPageLayout id="AuthDetailObjectPageLayoutId">
        <!-- HEADER -->
        <f:headerTitle>
            <!-- TITLE | SUBTITLE -->
            <f:ObjectPageDynamicHeaderTitle id="HeaderTitleId">
                <f:heading>
                    <Title id="TitleSession" text="{detailData>/SessionId}" level="H2" />
                </f:heading>
                <f:expandedContent>
                    <Text id="SubTitle" text="{i18n>authDetailSubtitle}" />
                </f:expandedContent>
            </f:ObjectPageDynamicHeaderTitle>
        </f:headerTitle>

        <!-- HEADER CONTENT -->
        <f:headerContent>
            <!-- USER CARD -->
            <HBox id="HeaderUserHBox" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                <!-- AVATAR -->
                <Avatar id="AvatarUser" displaySize="L" class="sapUiSmallMarginEnd" />

                <VBox id="UserInfoBox">
                    <!-- TITLE -->
                    <Title id="TitleUsername" text="{detailData>/Username}" level="H5" />

                    <!-- LOGIN RESULT -->
                    <ObjectStatus id="StatusLoginResultHeader" text="{detailData>/LoginResult}" state="{
                        path: 'detailData>/LoginResult',
                        formatter: '.formatter.formatLoginResultState'
                    }" icon="{
                        path: 'detailData>/LoginResult',
                        formatter: '.formatter.formatLoginResultIcon'
                    }" class="sapUiSmallMarginBottom" />

                    <Label id="LabelClient" text="{i18n>client}" design="Bold" />
                    <Text id="TextClient" text="{detailData>/UserClient}" />

                    <Label id="LabelSystem" text="{i18n>system}" design="Bold" class="sapUiSmallMarginTop" />
                    <Text id="TextSyste" text="{detailData>/UserSystem}" />
                </VBox>
            </HBox>
        </f:headerContent>

        <!-- SECTIONS -->
        <f:sections>
            <!-- DETAIL SECTIONS -->
            <f:ObjectPageSection id="SectionDetail" title="{i18n>headerTitleTable}">
                <f:subSections>
                    <f:ObjectPageSubSection id="SubSectionDetail">
                        <layout:Grid id="GridDetail" defaultSpan="L2 M4 S12">
                            <!-- COLUMN 1 -->
                            <VBox id="BoxUserInfo">
                                <!-- USER SESSION -->
                                <Label id="LabelSessionId" text="{i18n>sessionId}" design="Bold" />
                                <Text id="TextSessionId" text="{detailData>/SessionId}" />

                                <!-- USERNAME -->
                                <Label id="LabelUsername" text="{i18n>username}" design="Bold" class="sapUiSmallMarginTop" />
                                <Text id="TextUsername" text="{detailData>/Username}" />
                            </VBox>

                            <!-- COLUMN 2 -->
                            <VBox id="BoxLoginResult">
                                <!-- LOGIN RESULT -->
                                <Label id="LabelLoginResultId" text="{i18n>loginResult}" design="Bold" />
                                <ObjectStatus id="StatusLoginResultId" text="{detailData>/LoginResult}" state="{path: 'detailData>/LoginResult', formatter: '.formatter.formatLoginResultState'}" icon="{path: 'detailData>/LoginResult', formatter: '.formatter.formatLoginResultIcon'}" />

                                <!-- LOGIN MESSAGE -->
                                <Label id="LabelLoginMessageId" text="{i18n>loginMessage}" design="Bold" class="sapUiSmallMarginTop" />
                                <ObjectStatus id="StatusLoginMessageId" text="{detailData>/LoginMessage}" state="{path: 'detailData>/EventId', formatter: '.formatter.formatLoginMessageState'}" icon="{path: 'detailData>/EventId', formatter: '.formatter.formatLoginMessageIcon'}" />
                            </VBox>

                            <!-- COLUMN 3 -->
                            <VBox id="BoxEventInfo">
                                <!-- TERMINAL ID -->
                                <Label id="LabelTerminal" text="{i18n>terminalId}" design="Bold" />
                                <Text id="TextTerminal" text="{detailData>/TerminalId}" />
                                <!-- EVENT ID -->
                                <Label id="LabelEvent" text="{i18n>eventId}" design="Bold" class="sapUiSmallMarginTop" />
                                <ObjectStatus id="StatusEvent" text="{detailData>/EventId}" state="{path: 'detailData>/EventId', formatter: '.formatter.formatLoginMessageState'}" />
                            </VBox>

                            <!-- COLUMN 4 -->
                            <VBox id="BoxLoginTimeInfo">
                                <!-- LOGIN DATE -->
                                <Label id="LabelLoginDateId" text="{i18n>loginDate}" design="Bold" />
                                <Text id="TextLoginDateId" text="{path:'detailData>/LoginDate', formatter: '.formatter.formatISODate'}" />
                                <!-- LOGIN TIME -->
                                <Label id="LabelLoginTimeId" text="{i18n>loginTime}" design="Bold" class="sapUiSmallMarginTop" />
                                <Text id="TextLoginTimeId" text="{detailData>/LoginTime}" />
                            </VBox>

                            <!-- COLUMN 5 -->
                            <VBox id="BoxLogoutTimeInfo">
                                <!-- LOGOUT DATE -->
                                <Label id="LabelLogoutDateId" text="{i18n>logoutDate}" design="Bold" />
                                <Text id="TextLogoutDateId" text="{path:'detailData>/LogoutDate', formatter: '.formatter.formatISODate'}" />
                                <!-- LOGOUT TIME -->
                                <Label id="LabelLogoutTimeId" text="{i18n>logoutTime}" design="Bold" class="sapUiSmallMarginTop" />
                                <Text id="TextLogoutTimeId" text="{path:'detailData>/LogoutTime', formatter: '.formatter.formatLogoutTime'}" />
                            </VBox>

                            <!-- COLUMN 6 -->
                            <VBox id="BoxEmail">
                                <!-- SEND EMAIL -->
                                <Label id="LabelSendEmailId" text="{i18n>sendEmail}" design="Bold" />
                                <core:Icon id="icon" src="{= ${detailData>/SendMailFlag} ? 'sap-icon://accept' : 'sap-icon://decline'}" color="{= ${detailData>/SendMailFlag} ? 'green' : 'red'}" size="1.5rem" />
                            </VBox>
                        </layout:Grid>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>

            <!-- ACTIVITY SECTIONS -->
            <f:ObjectPageSection id="SectionActivity" title="{i18n>activityLog}">
                <f:subSections>
                    <f:ObjectPageSubSection id="SubSectionActivity">

                        <VBox id="ActivityVBox" class="sapUiMediumMarginTop">

                            <!-- FILTER TOOLBAR -->
                            <Panel id="activityFilterPanel" width="100%" headerText="{i18n>filter}" expandable="true" expanded="true" class="customFilterPanel sapUiSmallMarginBottom">
                                <Toolbar id="ActivityFilterToolbar" class="sapUiSmallMarginBottom" design="Transparent">
                                    <!-- Activity Type -->
                                    <Label id="ActivityTypeLabel" text="{i18n>activityType}" class="sapUiTinyMarginEnd" />
                                    <Select id="activityTypeFilter" width="140px" change="onFilterActivity">
                                        <core:Item id="all" key="" text="{i18n>itemAll}" />
                                        <core:Item id="tcode" key="TCODE" text="{i18n>itemTcode}" />
                                        <core:Item id="dump" key="DUMP" text="{i18n>itemDump}" />
                                    </Select>

                                    <!-- Tcode -->
                                    <Label id="ActivityTCodeLabel" text="{i18n>tCode}" class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
                                    <Input id="activityTCodeFilter" width="200px" placeholder="{i18n>tCode}" showValueHelp="true" liveChange="onApplyFilters" valueHelpRequest="onUserSearchHelpTCode" showClearIcon="true" class="sapUiSmallMarginEnd" />
                                </Toolbar>
                            </Panel>

                            <!-- TABLE -->
                            <ui:Table id="ActivityTable" rows="{detailData>/_Activity}" selectionMode="None" alternateRowColors="true">
                                <ui:extension>
                                    <OverflowToolbar id="ActivityTableToolbar">

                                        <!-- TITLE -->
                                        <Title id="ActivityTitle" text="{i18n>activityLog}" level="H6" />

                                        <ToolbarSpacer id="ActivityTableSpacer" />

                                        <!-- EXPORT -->
                                        <Button id="btnExportActivity" icon="sap-icon://excel-attachment" tooltip="Export Excel" press="onExportActivityExcel" />

                                        <!-- SETTINGS -->
                                        <Button id="btnActivitySettings" icon="sap-icon://action-settings" tooltip="Settings" press="onOpenActivitySettings" />
                                    </OverflowToolbar>
                                </ui:extension>

                                <ui:columns>
                                    <!-- LOGID COLUMN -->
                                    <ui:Column id="ColumnLogId" width="18rem" sortProperty="detailData>ActId" tooltip="{i18n>introSort}">
                                        <Label id="LabelLogId" text="{i18n>logId}" />

                                        <ui:template>
                                            <Text id="TextLogId" text="{detailData>ActId}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- ACTIVITY TYPE COLUMN -->
                                    <ui:Column id="ColumnActivityTypeId" width="8rem" sortProperty="detailData>ActType" tooltip="{i18n>introSort}">
                                        <Label id="LabelActivityType" text="{i18n>activityType}" />

                                        <ui:template>
                                            <ObjectStatus id="ObjectStatusActivityType" text="{detailData>ActType}" icon="{path:'detailData>ActivityType', formatter: '.formatter.formatActivityType'}" state="{path:'detailData>ActivityType', formatter: '.formatter.formatActivityState'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- TCODE COLUMN -->
                                    <ui:Column id="ColumnTCodeId" width="6rem" sortProperty="detailData>Tcode" tooltip="{i18n>introSort}">
                                        <Label id="LabelTCode" text="{i18n>tCode}" />

                                        <ui:template>
                                            <ObjectStatus id="ObjectStatusTCode" text="{detailData>Tcode}" icon="{path:'detailData>TCode', formatter: '.formatter.formatTCodeIcon'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- TCODE NAME COLUMN -->
                                    <ui:Column id="ColumnTCodeNameId" width="8rem" sortProperty="detailData>TCodeName" tooltip="{i18n>introSort}">
                                        <Label id="LabelTCodeName" text="{i18n>tCodeName}" />

                                        <ui:template>
                                            <Text id="TextTCodeName" text="{detailData>TCodeName}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- ACTIVITY MESSAGE COLUMN -->
                                    <ui:Column id="ColumnMsgId" sortProperty="detailData>MessageText" tooltip="{i18n>introSort}">
                                        <Label id="LabelActivityMessage" text="{i18n>activityMessage}" />

                                        <ui:template>
                                            <ObjectStatus id="StatusActivityMessage" text="{detailData>MessageText}" state="Information" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- DATE COLUMN -->
                                    <ui:Column id="ColumnDateId" width="8rem" sortProperty="detailData>ActDate" tooltip="{i18n>introSort}">
                                        <Label id="LabelActivityDate" text="{i18n>activityDate}" />

                                        <ui:template>
                                            <Text id="TextActivityDate" text="{detailData>ActDate}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- TIME COLUMN -->
                                    <ui:Column id="ColumnTieId" width="8rem" sortProperty="detailData>ActTims" tooltip="{i18n>introSort}">
                                        <Label id="LabelActivityTime" text="{i18n>activityTime}" />

                                        <ui:template>
                                            <Text id="TextActivityTime" text="{detailData>ActTims}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- SENT MAIL -->
                                    <ui:Column id="ColumnNavId" width="4rem" hAlign="Center">
                                        <Label id="ActivitySentMaileColumnLabel" text="{i18n>sentMailAlert}" />
                                        <ui:template>
                                            <core:Icon id="ActivitySentMailId" src="{= ${detailData>MailSent} ? 'sap-icon://email' : 'sap-icon://less'}" color="{= ${detailData>mail_sent} ? 'Positive' : 'Neutral'}" size="1.5rem" />
                                        </ui:template>
                                    </ui:Column>
                                </ui:columns>
                            </ui:Table>
                        </VBox>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>
        </f:sections>
    </f:ObjectPageLayout>
</mvc:View>